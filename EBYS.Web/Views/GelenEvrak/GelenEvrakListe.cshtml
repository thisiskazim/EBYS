<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3 d-flex justify-content-between align-items-center">
        <h4 class="m-0 text-primary fw-bold">
            <i class="fas fa-inbox me-2"></i>Gelen Evrak Kayıt Listesi
        </h4>
        <a href="/GelenEvrak/EvrakOlustur" class="btn btn-success btn-sm">
            <i class="fas fa-plus me-1"></i>Yeni Gelen Evrak
        </a>
    </div>

    <div class="bg-light border-top border-bottom px-3 py-3">
        <div class="row g-2 align-items-end">
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Oluşturan</label>
                <input type="text" id="filterOlusturan" class="form-control form-control-sm border-2" placeholder="Personel adı...">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Konu</label>
                <input type="text" id="filterKonu" class="form-control form-control-sm border-2" placeholder="Evrak konusu...">
            </div>
            <div class="col-md-3">
                <label class="form-label small fw-bold text-muted text-uppercase">Konu Kodu</label>
                <input type="text" id="filterKonuKodu" class="form-control form-control-sm border-2" placeholder="Kod veya tanım...">
            </div>
            <div class="col-md-3">
                <button class="btn btn-primary btn-sm w-100 fw-bold" onclick="GelenEvrakListModule.filterGrid()">
                    <i class="fas fa-search me-1"></i> SORGULA
                </button>
            </div>
        </div>
    </div>

    <div class="card-body p-0">
        <div id="gridGelenEvraklar"></div>
    </div>
</div>

@await Html.PartialAsync("Components/_EvrakOnizlemePartial")



<script src="~/js/GelenEvrak/gelenevrak-list.js"></script>