<div class="container-fluid py-3" style="background-color: #f8fafc; min-height: 90vh;">

    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h4 class="m-0 text-dark" style="letter-spacing: -0.5px;">Gelen Evrak Merkezi</h4>
        
        </div>
        <div class="d-flex gap-2">
            <button class="btn btn-outline-secondary btn-sm fw-bold px-3 border-2" onclick="GelenEvrakListModule.openFilterWindow()">
                <i class="fas fa-sliders-h me-1"></i> Gelişmiş Filtre
            </button>
            <a href="/GelenEvrak/EvrakOlustur" class="btn btn-success btn-sm fw-bold px-3 shadow-sm">
                <i class="fas fa-plus me-1"></i> Yeni Gelen Evrak
            </a>
        </div>
    </div>

    <div class="card shadow-sm border-0" style="border-radius: 16px; overflow: hidden;">
        <div class="card-header bg-white pt-3 pb-0 px-4 border-0">
            <ul class="nav nav-tabs border-bottom-0" id="evrakTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active fw-bold px-4 pb-3 position-relative text-secondary"
                            id="tumEvraklar-tab" data-bs-toggle="tab" data-bs-target="#tumEvraklar" type="button"
                            onclick="GelenEvrakListModule.changeTab('tum')">
                        <i class="fas fa-list-ul me-2"></i>Tüm Gelen Evraklar
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 pb-3 position-relative text-secondary"
                            id="adimaGelenler-tab" data-bs-toggle="tab" data-bs-target="#adimaGelenler" type="button"
                            onclick="GelenEvrakListModule.changeTab('adima')">
                        <i class="fas fa-user-check me-2"></i>Şahsıma Sevk Edilenler
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 pb-3 position-relative text-secondary"
                            id="iadeEttiklerim-tab" data-bs-toggle="tab" data-bs-target="#iadeEttiklerim" type="button"
                            onclick="GelenEvrakListModule.changeTab('iade')">
                        <i class="fas fa-undo-alt me-2"></i>İade Ettiklerim
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link fw-bold px-4 pb-3 position-relative text-secondary"
                            id="cevapladiklarim-tab" data-bs-toggle="tab" data-bs-target="#cevapladiklarim" type="button"
                            onclick="GelenEvrakListModule.changeTab('cevap')">
                        <i class="fas fa-reply me-2"></i>Cevapladıklarım
                    </button>
                </li>
            </ul>
        </div>

        <div class="card-body p-0 bg-white">
            <div class="tab-content">
                <div class="tab-pane fade show active" id="centralTabContent" role="tabpanel">
                    <div id="gridGelenEvraklar" class="border-0"></div>
                </div>
            </div>
        </div>
    </div>
</div>

<div id="filterWindow" style="display: none;">
    <div class="container-fluid py-2">
        <div class="row g-3">
            <div class="col-12">
                <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Oluşturan Personel</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-2 text-muted"><i class="fas fa-user"></i></span>
                    <input type="text" id="filterOlusturan" class="form-control border-2 shadow-none" placeholder="Personel adı soyadı...">
                </div>
            </div>
            <div class="col-12">
                <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Evrak Konusu</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-2 text-muted"><i class="fas fa-file-alt"></i></span>
                    <input type="text" id="filterKonu" class="form-control border-2 shadow-none" placeholder="Evrak konusu veya içeriği...">
                </div>
            </div>
            <div class="col-12">
                <label class="form-label small fw-bold text-secondary text-uppercase mb-1">Konu Kodu (SDP)</label>
                <div class="input-group">
                    <span class="input-group-text bg-white border-2 text-muted"><i class="fas fa-hashtag"></i></span>
                    <input type="text" id="filterKonuKodu" class="form-control border-2 shadow-none" placeholder="Örn: 632.12">
                </div>
            </div>
        </div>

        <hr class="my-4 opacity-50">

        <div class="d-flex justify-content-end gap-2">
            <button class="btn btn-light fw-bold px-4" onclick="GelenEvrakListModule.clearFilters()">Temizle</button>
            <button class="btn btn-primary fw-bold px-4 shadow-sm" onclick="GelenEvrakListModule.filterGrid()">
                <i class="fas fa-search me-1"></i> Sorgula
            </button>
        </div>
    </div>
</div>

<div id="historyWindow" style="display: none;">
    <div class="p-2">
        <div id="historyGrid"></div>
    </div>
</div>

@await Html.PartialAsync("Components/_EvrakOnizlemePartial")

<style>
    /* Aktif sekme çizgisi tasarımı */
    #evrakTabs .nav-link {
        border: none;
        background: none;
        transition: all 0.2s ease;
        font-size: 14px;
    }

        #evrakTabs .nav-link:hover {
            color: #3b82f6 !important;
        }

        #evrakTabs .nav-link.active {
            color: #2563eb !important;
        }

            #evrakTabs .nav-link.active::after {
                content: '';
                position: absolute;
                bottom: 0;
                left: 24px;
                right: 24px;
                height: 3px;
                background-color: #2563eb;
                border-radius: 3px 3px 0 0;
            }
    /* Kendo Grid Kurumsal Softlaştırma */
    .k-grid {
        font-family: inherit;
        border: none !important;
    }

    .k-grid-header {
        background-color: #f1f5f9 !important;
        border-bottom: 2px solid #e2e8f0 !important;
    }

        .k-grid-header th.k-header {
            background: none !important;
            color: #475569 !important;
            font-weight: 700 !important;
            text-uppercase: uppercase;
            font-size: 11px;
            letter-spacing: 0.5px;
            padding: 14px !important;
        }

    .k-grid td {
        padding: 12px 14px !important;
        border-bottom: 1px solid #f1f5f9 !important;
        color: #334155 !important;
    }
    /* Badge Tasarımları */
    .badge {
        padding: 6px 10px !important;
        font-weight: 600 !important;
        border-radius: 8px !important;
    }

    .bg-info {
        background-color: #e0f2fe !important;
        color: #0369a1 !important;
    }

    .bg-warning {
        background-color: #fef3c7 !important;
        color: #b45309 !important;
    }
</style>

<script src="~/js/GelenEvrak/gelenevrak-list.js"></script>