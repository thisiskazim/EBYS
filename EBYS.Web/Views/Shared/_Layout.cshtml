<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - EBYS.Web</title>
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <!-- Kendo theme -->
    <link rel="stylesheet" href="https://cdn.kendostatic.com/2026.1.212/styles/kendo.default-v2.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/EBYS.Web.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://kendo.cdn.telerik.com/themes/10.0.1/default/default-main.css" />

    <link rel="stylesheet" href="https://kendo.cdn.telerik.com/icons/10.0.0/default/default-main.css" />
	<script src="https://code.jquery.com/jquery-3.7.1.min.js"></script>
	<script src="https://unpkg.com/jszip/dist/jszip.min.js"></script>
	<script src="https://cdn.kendostatic.com/2026.1.212/js/kendo.all.min.js"></script>
	<script src="https://cdn.kendostatic.com/2026.1.212/js/kendo.aspnetmvc.min.js"></script>

    <style>
        /* Small inline helper to ensure body stretches full height for sidebar */
        html, body { height: 100%; }
    </style>
</head>
<body class="k-body">
  
    <div class="ebys-app d-flex">
        @if (!(ViewData["HideMenu"] as bool? ?? false))
        {
            <!-- Left visual sidebar -->
            <aside class="ebys-sidebar-modern bg-dark text-white">
                <div class="sidebar-inner p-3">
                    <div class="menu-header text-uppercase small text-white-50 mb-3">Menü</div>

                    <nav class="nav flex-column">
                        <a class="nav-link menu-item d-flex align-items-start text-white mb-2" href="/">
                            <div class="menu-icon me-3 d-flex align-items-center justify-content-center bg-white text-dark">
                                <span class="k-icon k-i-home"></span>
                            </div>
                            <div class="menu-text">
                                <div class="menu-title">Ana Sayfa</div>
                            </div>
                        </a>

                        <div class="menu-section mb-2">
                            <a class="nav-link menu-item d-flex align-items-start text-white" data-bs-toggle="collapse" href="#evrakCollapse" role="button" aria-expanded="false" aria-controls="evrakCollapse">
                                <div class="menu-icon me-3 d-flex align-items-center justify-content-center bg-white text-dark">
                                    <span class="k-icon k-i-folder-open"></span>
                                </div>
                                <div class="menu-text">
                                    <div class="menu-title">Evrak İşlemleri</div>
                                    <div class="menu-sub small text-white-50">Yeni evrak, Gelen Evraklar</div>
                                </div>
                            </a>

                            <div class="collapse ps-5 mt-2" id="evrakCollapse">
                                <a class="nav-link small text-white-50 mb-1" href="/Evrak/Yeni">• Yeni evrak oluştur</a>
                                <a class="nav-link small text-white-50 mb-1" href="/Evrak/Gelen">• Gelen Evraklar</a>
                                <a class="nav-link small text-white-50" href="/Evrak/Tum">• Tüm Evraklar</a>
                            </div>
                        </div>



                        <div class="menu-section mb-2">
                            <a class="nav-link menu-item d-flex align-items-start text-white" data-bs-toggle="collapse" href="#geneltanimlar" role="button" aria-expanded="false" aria-controls="evrakCollapse">
                                <div class="menu-icon me-3 d-flex align-items-center justify-content-center bg-white text-dark">
                                    <span class="k-icon k-i-folder-open"></span>
                                </div>
                                <div class="menu-text">
                                    <div class="menu-title">Genel Tanımlar</div>
                                    <div class="menu-sub small text-white-50">İmza Rota,Kurumlar,Vatandaş,Tüzel Kişi</div>
                                </div>
                            </a>
                        <div class="collapse ps-5 mt-2" id="geneltanimlar">
                                <a class="nav-link small text-white-50 mb-1" href="/Muhatap/EkleKurum">• Kurum Ekle ve Listele</a>
                            <a class="nav-link small text-white-50 mb-1" href="/Muhatap/EkleBireyselVatandas">• Vatandaş Ekle ve Listele</a>
                            <a class="nav-link small text-white-50" href="/Muhatap/EkleTüzelKisi">• Tüzel Kişi Ekle ve Listele</a>
                            </div>
                        </div>

                        
                       
                    </nav>
               </div>
            </aside>
        }

        <!-- Main content area -->
        <main class="ebys-main flex-fill">
            <div class="container-fluid p-4">
            @RenderBody()
            </div>
        </main>
    </div>

    <!-- Bootstrap JS for collapse; site script -->
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @(Html.Kendo().Notification()
        .Name("notification")
        .Position(p => p.Pinned(true).Bottom(30).Right(30)) // Sağ Alt
        .Stacking(NotificationStackingSettings.Up) // Yeni gelen üstte birikir
        .AutoHideAfter(5000) // 5 saniye görünsün
        .Width(450) // Genişliği artırdık
        .Templates(t => {
            t.Add().Type("error").ClientTemplate("<div class='k-notification-error k-notification-wrap k-icon'><span class=' k-i-warning'></span> #= message #</div>");
            t.Add().Type("success").ClientTemplate("<div class='k-notification-success k-notification-wrap'><span class='k-icon k-i-check-circle'></span> #= message #</div>");
        })
    )

    <script>
    function showNotification(msg, type) {
        var notification = $("#notification").data("kendoNotification");
        notification.show({ message: msg }, type);
    }


    // Sayfa yüklenir yüklenmez bak: Token yoksa login'e fırlat!

</script>
    @await RenderSectionAsync("Scripts", required: false)

</body>

</html>
@* <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script> *@
@* @await RenderSectionAsync("Scripts", required: false) *@