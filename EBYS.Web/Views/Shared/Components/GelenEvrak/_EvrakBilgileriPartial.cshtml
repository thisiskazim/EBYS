<div class="tab-pane fade show active" id="bilgiler" role="tabpanel">
    <div class="card mt-3 shadow-sm">
        <div class="card-header bg-white d-flex align-items-center justify-content-between">
            <h5 class="mb-0">Evrak Bilgileri</h5>
            <div class="form-check form-switch m-0">
                <input class="form-check-input" type="checkbox" id="DilekceMi">
                <label class="form-check-label ms-2" for="DilekceMi">Dilekçe Mi?</label>
            </div>
        </div>
        <div class="card-body">
            <div class="row g-3">
                <div class="col-12 col-lg-6">
                    <label class="form-label fw-bold"><i class="k-icon k-i-user me-1"></i> Evrak Üretici *</label>
                    @(Html.Kendo().ComboBox()
                        .Name("MuhatapId")
                        .Placeholder("Rehberden gönderen seçiniz...")
                        .DataTextField("adi")
                        .DataValueField("id")
                        .Filter(FilterType.Contains)
                        .DataSource(ds => ds.Read(r => r.Url("https://localhost:7060/api/Muhatap/TumMuhataplar").Type(HttpVerbs.Get)))
                        .HtmlAttributes(new { @class = "form-control" , style = "width:100%" })
                    )
                </div>

                <div class="col-12 col-lg-6">
                    <label class="form-label fw-bold">Konu Kodu (Desimal) *</label>
                    @(Html.Kendo().ComboBox()
                        .Name("KonuKodu")
                        .Placeholder("Kod seçiniz...")
                        .DataTextField("fullKod")
                        .DataValueField("fullKod")
                        .Filter(FilterType.Contains)
                        .DataSource(ds => ds.Read(r => r.Url("https://localhost:7060/api/GidenEvrak/KonuKoduGet").Type(HttpVerbs.Get)))
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>

                <div class="col-12">
                    <label class="form-label fw-bold">Evrak Konusu *</label>
                    <input class="form-control" id="Konu" placeholder="Evrakın konusunu giriniz..." />
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label">Gelen Evrak Sayısı</label>
                    <input class="form-control" id="EvrakSayisi" placeholder="Dış Kurum Sayısı" />
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label">Gelen Evrak Tarihi</label>
                    @(Html.Kendo().DatePicker()
                        .Name("EvrakTarihi")
                        .Value(DateTime.Now)
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label text-primary fw-bold">Defter Tarihi (Sisteme Giriş)</label>
                    @(Html.Kendo().DatePicker()
                        .Name("DefterTarihi")
                        .Value(DateTime.Now)
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>

                <div class="col-12 col-md-6 col-lg-3">
                    <label class="form-label">Cevap İstenen Tarih</label>
                    @(Html.Kendo().DatePicker()
                        .Name("CevapIstenenTarih")
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">Gizlilik Derecesi</label>
                    @(Html.Kendo().DropDownList()
                        .Name("GizlilikDerecesi")
                        .BindTo(new[] {
                            new { text = "TASNİF DIŞI", value = 0 },
                            new { text = "GİZLİ", value = 1 }
                        })
                        .DataTextField("text")
                        .DataValueField("value")
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>

                <div class="col-12 col-md-6">
                    <label class="form-label">İvedilik Derecesi</label>
                    @(Html.Kendo().DropDownList()
                        .Name("IvedilikDerecesi")
                        .BindTo(new[] {
                            new { text = "NORMAL", value = 0 },
                            new { text = "ACİL", value = 1 }
                        })
                        .DataTextField("text")
                        .DataValueField("value")
                        .HtmlAttributes(new { @class = "form-control", style = "width:100%" })
                    )
                </div>
            </div>
        </div>
        <div class="card-footer text-muted small">
            Zorunlu alanlar * ile belirtilmiştir.
        </div>
    </div>

    <script src="~/js/GidenEvrak/evrak-bilgileri.js"></script>
</div>

