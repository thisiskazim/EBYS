<div class="tab-pane fade show active" id="bilgiler" role="tabpanel">
    <div class="card-body p-4" style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial; color: #343a40;">
    <div class="row">
        <div class="col-md-5">
            <div class="mb-3">
                <label class="form-label text-secondary">Konu Kodu *</label>
                @(Html.Kendo().ComboBox()
                                .Name("KonuKoduId") 
                                .Placeholder("Kod veya konu adı ile arayın...")
                                .DataTextField("fullKod")
                                .DataValueField("id")
                                .Filter(FilterType.Contains)
                                .AutoBind(true)
                                .Suggest(true)
                                .DataSource(ds => ds
                                .Read(r => r.Url("https://localhost:7060/api/GidenEvrak/KonuKoduGet").Type(HttpVerbs.Get))
                                )
                                .HtmlAttributes(new { style = "width:100%", @class = "form-control bg-white" })
                                )
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary">Konu *</label>
                <input class="form-control bg-white" id="konu" placeholder="Konu" />
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary">İmza Rota *</label>
                @(Html.Kendo().DropDownList()
                                .Name("imzaRota")
                                .HtmlAttributes(new { style = "width:100%", @class = "form-control bg-white", id = "ImzaRota" })
                                .OptionLabel("Seçiniz")
                                .DataTextField("rotaAdi")
                                .DataValueField("id")
                                .OptionLabel("Seçiniz")
                                .DataSource(ds => ds.Read(r => r.Url("https://localhost:7060/api/ImzaRota/ImzaRotaListesi").Type(HttpVerbs.Get)))
                                )
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary">Evrak Tarihi</label>
                <input class="form-control bg-white" value="Otomatik" disabled />
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary">Gizlilik Derecesi</label>
                @(Html.Kendo().DropDownList()
                                .Name("gizlilik")
                                .BindTo(new[] { new { text = "TASNİF DIŞI", value = "0" }, new { text = "GİZLİ", value = "1" } })
                                .DataTextField("text")
                                .DataValueField("value")
                                .HtmlAttributes(new { @class = "form-control bg-white" })
                                )
            </div>

            <div class="mb-3">
                <label class="form-label text-secondary">İvedilik</label>
                @(Html.Kendo().DropDownList()
                                .Name("ivedilik")
                                .BindTo(new[] { new { text = "NORMAL", value = "0" }, new { text = "ACİL", value = "1" } })
                                .DataTextField("text")
                                .DataValueField("value")
                                .HtmlAttributes(new { @class = "form-control bg-white" })
                                )
            </div>

        </div>

        <div class="col-md-7">
            <div class="mb-2 d-flex justify-content-between align-items-center">
                <div>
                    <label class="form-label mb-0 text-secondary">Evrak İçeriği *</label>
                </div>
                <div class="text-muted small">Yazı tipi, hizalama ve tablo seçenekleri kullanılabilir.</div>
            </div>

            @(Html.Kendo().Editor()
                .Name("EvrakEditor")
                .Tools(tools => tools
                    .Clear().Bold().Italic().Underline().Separator()
                    .InsertUnorderedList().InsertOrderedList().Separator()
                    .JustifyLeft().JustifyCenter().JustifyRight().Separator()
                    .FontName().FontSize()
                )
                .HtmlAttributes(new { style = "height:420px;", @class = "custom-editor" })
            )
        </div>
    </div>

    <hr />

    <div class="mb-3">
        <label class="form-label text-secondary">Ek Üstünde-İmza Altında Metin Girişi</label>
        @(Html.Kendo().Editor()
                .Name("AltMetinEditor")
                .Tools(tools => tools
                .Clear().Bold().Italic().Underline().Separator()
                .InsertUnorderedList().InsertOrderedList().Separator()
                .JustifyLeft().JustifyCenter().JustifyRight().Separator()
                .FontName().FontSize()
                )
                .HtmlAttributes(new { style = "height:150px;" })
                )
    </div>

</div>


</div>


<script src="~/js/GidenEvrak/evrak-bilgileri.js"></script>

                        

