@model PageHeaderModel


<div class="row page-titles mb-4 shadow-sm bg-white py-3 px-2 rounded-1 border-start align-items-center">
    <div class="col-md-7 align-self-center">
        <h4 class="mb-1 text-dark fw-bold" style="letter-spacing: -0.5px;">@Model.Title</h4>
        <nav aria-label="breadcrumb">
            <ol class="breadcrumb m-0 fs-13">
                <li class="breadcrumb-item"><a href="javascript:void(0)" class="text-muted">@Model.BreadcrumbParent</a></li>
                <li class="breadcrumb-item active text-info fw-semibold">@Model.BreadcrumbCurrent</li>
            </ol>
        </nav>
    </div>
    
    <div class="col-md-5 align-self-center text-end d-flex justify-content-end gap-2 align-items-center">
        


        @if (Model.ShowFilterButton)
        {
            <button class="btn btn-sm btn-outline-secondary waves-effect shadow-sm px-3" onclick="@Model.FilterJsFunction">
                <i class="ri-filter-3-line me-1"></i> Filtrele
            </button>
        }
        
        @if (Model.ShowNewActionButton)
        {
  
            if (Model.NewActionUrl.StartsWith("javascript:"))
            {
                var jsFunc = Model.NewActionUrl.Replace("javascript:", "");
                <button onclick="@jsFunc" class="btn btn-sm btn-info waves-effect waves-light shadow-sm text-white px-3 fw-semibold">
                    <i class="ri-add-circle-line me-1"></i> @Model.NewActionText
                </button>
            }
            else
            {
                <a href="@Model.NewActionUrl" class="btn btn-sm btn-info waves-effect waves-light shadow-sm text-white px-3 fw-semibold">
                    <i class="ri-add-circle-line me-1"></i> @Model.NewActionText
                </a>
            }
        }
    </div>
</div>

<style>
    /* Yol belirteci font boyutu standardı */
    .fs-13 {
        font-size: 13px !important;
    }
    /* Çerçevenin genel formu */
    .page-titles {
        margin-right: 0px !important;
        margin-left: 0px !important;
        background: #ffffff;
    }
</style>

