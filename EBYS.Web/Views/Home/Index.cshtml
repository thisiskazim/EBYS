@{
    ViewData["Title"] = "Evrak Oluştur";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0"><span class="k-icon k-i-file-pdf"></span> Evrak Oluştur <small class="text-muted ms-2">Bilgileri doldurun</small></h4>
    <input type="hidden" id="EvrakId" value="@ViewBag.EvrakId" />
    <div>
        <button class="btn btn-warning me-2"><span class="k-icon k-i-save"></span> Taslak Olarak Kaydet</button>
        <button id="evrakKaydet" class="btn btn-primary"><span class="k-icon k-i-file"></span> Evrak Oluştur</button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <ul class="nav nav-tabs mb-3" id="evrakTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="bilgiler-tab" data-bs-toggle="tab" data-bs-target="#bilgiler" type="button" role="tab">Bilgileri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="alici-tab" data-bs-toggle="tab" data-bs-target="#alici" type="button" role="tab">Alıcı Ekle</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="ekler-tab" data-bs-toggle="tab" data-bs-target="#ekler" type="button" role="tab">Ekleri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="ilgili-tab" data-bs-toggle="tab" data-bs-target="#ilgili" type="button" role="tab">İlgilileri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="gorunum-tab" data-bs-toggle="tab" data-bs-target="#gorunum" type="button" role="tab">Evrak Görünüm</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="bilgiler">
                @await Html.PartialAsync("Components/Evrak/_EvrakBilgileriPartial")
            </div>

            <div class="tab-pane fade" id="alici">
                @await Html.PartialAsync("Components/Evrak/_AliciBilgileriPartial")
            </div>

      
            <div class="tab-pane fade" id="ekler">
                @await Html.PartialAsync("Components/Evrak/_EklerPartial")
            </div>

            <div class="tab-pane fade" id="ilgili">
                @await Html.PartialAsync("Components/Evrak/_IlgilerPartial")
            </div>
            

            <div class="tab-pane fade" id="gorunum">
                @await Html.PartialAsync("Components/Evrak/_GorunumPartial")
            </div>

            
        </div>
    </div>
</div>


<script src="~/js/evrak/evrak-olustur.js"></script>

