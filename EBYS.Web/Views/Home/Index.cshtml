@{
    ViewData["Title"] = "Evrak Oluştur";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h4 class="m-0"><span class="k-icon k-i-file-pdf"></span> Evrak Oluştur <small class="text-muted ms-2">Bilgileri doldurun</small></h4>

    <div>
        <button class="btn btn-warning me-2"><span class="k-icon k-i-save"></span> Taslak Olarak Kaydet</button>
        <button class="btn btn-primary"><span class="k-icon k-i-file"></span> Evrak Oluştur</button>
    </div>
</div>

<div class="card">
    <div class="card-body">
        <ul class="nav nav-tabs mb-3" id="evrakTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active" id="bilgiler-tab" data-bs-toggle="tab" data-bs-target="#bilgiler" type="button" role="tab">Bilgileri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="alici-tab" data-bs-toggle="tab" data-bs-target="#alici" type="button" role="tab">Alıcı Ekle</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="ekler-tab" data-bs-toggle="tab" data-bs-target="#ekler" type="button" role="tab">Ekleri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="ilgili-tab" data-bs-toggle="tab" data-bs-target="#ilgili" type="button" role="tab">İlgilileri</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link" id="gorunum-tab" data-bs-toggle="tab" data-bs-target="#gorunum" type="button" role="tab">Evrak Görünüm</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="bilgiler" role="tabpanel">
                <div class="row">
                    <div class="col-md-5">
                        <div class="mb-3">
                            <label class="form-label">Konu Kodu *</label>
                            @(Html.Kendo().ComboBox()
                                .Name("konuKodu")
                                .Placeholder("Seçiniz")
                                .DataTextField("text")
                                .DataValueField("value")
                                .DataSource(ds => ds.Read(r => r.Url("/api/Kod/GetKonuKodlari").Type(HttpVerbs.Get)))
                            )
                        </div>

                        <div class="mb-3">
                            <label class="form-label text-danger">Konu Tırnak İşareti kullanmayınız! *</label>
                            <input class="form-control" id="konu" placeholder="Konu" />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">İmza Rota *</label>
                            @(Html.Kendo().DropDownList()
                                .Name("imzaRota")
                                .DataTextField("text")
                                .DataValueField("value")
                                .OptionLabel("Seçiniz")
                                .DataSource(ds => ds.Read(r => r.Url("/api/Imza/GetRotalar").Type(HttpVerbs.Get)))
                            )
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Evrak Tarihi</label>
                            <input class="form-control" value="Otomatik" disabled />
                        </div>

                        <div class="mb-3">
                            <label class="form-label">Gizlilik Derecesi</label>
                            @(Html.Kendo().DropDownList()
                                .Name("gizlilik")
                                .BindTo(new[] { new { text = "TASNİF DIŞI", value = "0" }, new { text = "GİZLİ", value = "1" } })
                                .DataTextField("text")
                                .DataValueField("value")
                            )
                        </div>

                        <div class="mb-3">
                            <label class="form-label">İvedilik</label>
                            @(Html.Kendo().DropDownList()
                                .Name("ivedilik")
                                .BindTo(new[] { new { text = "NORMAL", value = "0" }, new { text = "ACİL", value = "1" } })
                                .DataTextField("text")
                                .DataValueField("value")
                            )
                        </div>

                    </div>

                    <div class="col-md-7">
                        <div class="mb-2 d-flex justify-content-between align-items-center">
                            <div>
                                <label class="form-label mb-0">Evrak İçeriği</label>
                            </div>
                            <div class="text-muted small">Yazı tipi, hizalama ve tablo seçenekleri kullanılabilir.</div>
                        </div>

                        @(Html.Kendo().Editor()
                            .Name("EvrakEditor")
                            .Tools(tools => tools
                                .Formatting()
                                .Bold().Italic().Underline()
                                .Separator()
                                .InsertUnorderedList().InsertOrderedList()
                                .Separator()
                                .FontName().FontSize()
                            )
                            .HtmlAttributes(new { style = "height:420px;" })
                        )

                 

                    </div>
                </div>

                <hr />

                <div class="mb-3">
                    <label class="form-label">Ek Üstünde-İmza Altında Metin Girişi</label>
                    @(Html.Kendo().Editor()
                        .Name("AltMetinEditor")
                        .Tools(t => t.Bold().Italic().Underline().Separator().FontName().FontSize())
                        .HtmlAttributes(new { style = "height:120px;" })
                    )
                </div>

            </div>

            <div class="tab-pane fade" id="alici" role="tabpanel">
                <h6>Alıcı Ekle</h6>
                <p>Alıcılar buradan eklenir veya seçilir.</p>
                @(Html.Kendo().MultiSelect()
                    .Name("muhataplar")
                    .DataTextField("adi")
                    .DataValueField("id")
                    .Placeholder("Alıcı ismi giriniz...")
                    .Filter(FilterType.Contains)
                    .AutoBind(true)
                    .DataSource(source =>
                    {
                        source.Read(read => read.Url("/api/Muhatap/GetAlicilar").Type(HttpVerbs.Get));
                    })
                )
            </div>

            <div class="tab-pane fade" id="ekler" role="tabpanel">
                <h6>Ekler</h6>
                <p>Dosya yükleme ve ek yönetimi burada olacak.</p>
            </div>

            <div class="tab-pane fade" id="ilgili" role="tabpanel">
                <h6>İlgililer</h6>
                <p>İlgili kişileri seçin.</p>
            </div>

            <div class="tab-pane fade" id="gorunum" role="tabpanel">
                <h6>Evrak Görünüm</h6>
                <p>Oluşan evrakın önizlemesi buraya gelecek.</p>
            </div>
        </div>
    </div>
</div>








