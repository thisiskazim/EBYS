
<div class="container-fluid py-4">
    <div class="row align-items-center mb-4">
        <div class="col-md-6">
            <h3 class="mb-0">
                <i class="k-icon k-i-file-pdf" style="font-size: 24px;"></i>Kurum Bilgileri
            </h3>
        </div>
        <div class="col-md-6 text-md-end mt-3 mt-md-0">
            <input type="hidden" id="Id" value="@(ViewBag.KurumId ?? 0)" />
            <a class="btn btn-outline-info shadow-sm rounded-3 px-4 fw-bold" href="#">
                <i class="k-icon k-i-search me-2"></i>Kayıtlıdan Ara
            </a>
        </div>
        <div class="col-12">
            <hr class="mt-3" />
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-3">
        <div class="card-body p-4">
            <div class="row">
                <div class="col-md-6 border-end">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Kurum Adı *</label>
                        @(Html.Kendo().TextBox().Name("Adi")
                                                .Placeholder("Örn: Türk Hava Yolları")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "Adi" }))
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Kurum Kimlik Kodu</label>
                        @(Html.Kendo().TextBox().Name("KurumKodu")
                                                .Placeholder("Kurum kodu giriniz...")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "KurumKodu" }))
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Detsis No</label>
                        @(Html.Kendo().TextBox().Name("DetsisNo")
                                                .Placeholder("Detsis numarasını giriniz...")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "DetsisNo" }))
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Telefon</label>
                        @(Html.Kendo().TextBox().Name("Telefon")
                                                .Placeholder("0(5XX) XXX XX XX")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "Telefon" }))
                    </div>
                </div>

                <div class="col-md-6 ps-md-4">
                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Mail Adresi</label>
                        @(Html.Kendo().TextBox().Name("EPosta")
                                                .Placeholder("kurum@mail.com")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "EPosta" }))
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Kep Adresi</label>
                        @(Html.Kendo().TextBox().Name("KepAdresi")
                                                .Placeholder("kurum@hs01.kep.tr")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "KepAdresi" }))
                    </div>

                    <div class="mb-3">
                        <label class="form-label fw-bold text-muted small">Adres</label>
                        @(Html.Kendo().TextArea().Name("Adress")
                                                .Rows(3)
                                                .Placeholder("Tam adres bilgisi...")
                                                .HtmlAttributes(new { style = "width: 100%", @class = "form-control rounded-2", id = "Adress" }))
                    </div>
                </div>
            </div>

            <div class="border-top pt-4 mt-4 d-flex justify-content-end gap-2">
                <a class="btn btn-light px-4 fw-bold text-muted border" href="/KurumMuhatap/Listele">
                    <i class="k-icon k-i-undo me-1"></i> Listeye Dön
                </a>
                <button id="btnKaydet" type="button" class="btn btn-success px-5 shadow-sm fw-bold" onclick="module.kaydet()">
                    <i class="k-icon k-i-save me-1"></i> Kaydet / Güncelle
                </button>
            </div>
        </div>
    </div>
</div>


<script src="~/js/KurumMuhatap/ekle.js"></script>
