<div id="onizlemeDialog">
    <div class="d-flex" style="height: 720px; margin: -16px;">
      
        <div class="bg-light border-end flex-shrink-0" style="width: 230px; overflow-y: auto;">
            <div class="p-3 border-bottom fw-bold text-secondary small">EVRAK DOSYALARI</div>
            <div class="list-group list-group-flush" id="popupDosyaListesi"></div>
        </div>

   
        <div class="flex-grow-1" style="background:#525659; overflow-y: auto; padding: 20px;">

          
            <div id="onizleme-yukleniyor" class="text-center mt-5 text-white" style="display:none;">
                <div class="spinner-border text-light"></div>
                <br>Yükleniyor...
            </div>


            <div class="flex-grow-1 preview-mode-parent" style="background:#525659; padding: 10px;">

                <div id="onizleme-panel-ana-yazi" class="preview-mode" style="display:none;">
                    <div class="a4-preview-wrapper shadow-lg mx-auto">
                        @await Html.PartialAsync("Components/Evrak/_GorunumPartial")
                    </div>
                </div>

                <div id="onizleme-panel-ekler" style="display:none; height: 100%; width:100%;">
                </div>
            </div>

 

        </div>
    </div>
</div>


<script src="~/js/Evrak/imza-bekleyen-evrak.js"></script>