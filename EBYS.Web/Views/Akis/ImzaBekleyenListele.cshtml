


<div class="card shadow-sm border-0">
    <div class="card-header bg-white py-3">
        <div class="col-md-12">
                <h4 class="m-0"><span class="k-icon k-i-file-pdf"></span>İmza Bekleyen Evraklar</h4>
            <hr />
        </div>
    </div>

        <div class="bg-light border-top border-bottom px-3 py-3">
            <div class="row g-2 align-items-end">
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Oluşturan</label>
                    <input type="text" id="filterOlusturan" class="form-control form-control-sm custom-filter-input" placeholder="Personel adı...">
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-bold text-muted">Konu</label>
                    <input type="text" id="filterKonu" class="form-control form-control-sm custom-filter-input" placeholder="Evrak konusu...">
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-bold text-muted">Konu Kodu / Adı</label>
                    <input type="text" id="filterKonuKodu" class="form-control form-control-sm custom-filter-input" placeholder="Kod veya tanım...">
                </div>
                <div class="col-md-2 d-flex gap-2">
                    <button class="btn btn-primary btn-sm w-100 fw-bold" onclick="filterGrid()">
                        <i class="fas fa-search me-1"></i> Sorgula
                    </button>
                   
                </div>
            </div>
        </div>

    <div class="card-body p-0">
        <div id="gridBekleyenler"></div>
    </div>
</div>
@await Html.PartialAsync("Components/Evrak/_GorunumPartial")
<div id="onizlemeDialog" style="display:none;">
    <div class="d-flex" style="height: 720px; margin: -16px;">
        <div class="bg-light border-end flex-shrink-0" style="width: 250px; overflow-y: auto;">
            <div class="p-3 border-bottom fw-bold text-primary small bg-white">
                <i class="fas fa-folder-open me-2"></i>EVRAK DOSYALARI
            </div>
            <div class="list-group list-group-flush" id="popupDosyaListesi">
            </div>
        </div>

        <div class="flex-grow-1" style="background:#525659; position: relative;">
            <div id="onizleme-yukleniyor" class="text-center mt-5 text-white" style="display:none; position: absolute; width: 100%; z-index: 99;">
                <div class="spinner-border text-light"></div><br>Hazırlanıyor...
            </div>
            
            <div id="pdf-viewer-wrapper" style="width: 100%; height: 850px; background: #525659; border-radius: 8px; overflow: hidden;">
                <iframe id="pdf-frame-popup" style="width: 100%; height: 100%; border: none;"></iframe>
            </div>

        </div>
    </div>
</div>


<script src="~/js/Evrak/imza-bekleyen-evrak.js"></script>
        